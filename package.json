{
  "name": "multi-author-blog-template",
  "version": "1.0.0",
  "private": true,
  "type": "module",
  "scripts": {
    "build": "node scripts/build.mjs",
    "build:optimized": "npm install sharp --save-dev && node scripts/build.mjs --optimize-images",
    "dev": "npm run build && python3 -m http.server 4173 --directory dist"
  },
  "devDependencies": {
    "sharp": "^0.33.5"
  },
  "dependencies": {
    "markdown-it": "^14.1.0",
    "markdown-it-footnote": "^3.0.3",
    "markdown-it-mark": "^4.0.0",
    "markdown-it-task-lists": "^2.1.1"
  }
}
